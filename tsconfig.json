{
  "compilerOptions": {
    "target": "ES2020",
    "module": "Node16",
    "moduleResolution": "node16",
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "types": ["cypress"],
    "lib": ["ES2020", "DOM"]
  },
  "include": ["cypress/**/*.ts", "cypress/**/*.d.ts"]
}